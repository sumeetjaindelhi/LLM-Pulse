{
  "name": "llm-pulse",
  "version": "0.1.0",
  "description": "Zero-config CLI for monitoring your local LLM hardware, runtimes, and model compatibility",
  "type": "module",
  "main": "dist/src/index.js",
  "bin": {
    "llm-pulse": "dist/bin/llm-pulse.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/bin/llm-pulse.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "llm",
    "gpu",
    "monitoring",
    "hardware",
    "ollama",
    "llama",
    "ai",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "boxen": "^8.0.1",
    "chalk": "^5.4.1",
    "cli-table3": "^0.6.5",
    "commander": "^13.1.0",
    "execa": "^9.5.2",
    "ink": "^6.8.0",
    "ora": "^8.2.0",
    "react": "^19.2.4",
    "systeminformation": "^5.24.6",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.9",
    "@types/react": "^19.2.14",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  },
  "engines": {
    "node": ">=18"
  }
}
